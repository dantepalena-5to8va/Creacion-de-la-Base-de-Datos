CREATE FUNCTION cantidad_compras_cliente(id_cliente INT)
RETURNS INT

BEGIN

DECLARE cantidad_compras INT;

SELECT COUNT(id) INTO cantidad_compras FROM Compras WHERE cliente = id_cliente;

END //
DELIMITER;

