DELIMITER //
CREATE FUNCTION total_gastado(id_cliente INT)
RETURNS DECIMAL(10,2)

BEGIN
DECLARE total DECIMAL (10,2);
SELECT SUM(Productos.precio) INTO total FROM Compras JOIN Producto ON Compras.producto = Productos.id WHERE cliente = id_cliente;

RETURN total;

END //
DELIMITER ;





