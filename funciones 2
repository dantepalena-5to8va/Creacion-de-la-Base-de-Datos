CREATE FUNCTION ultima_compra(id_cliente INT)
RETURNS DATE

BEGIN

DECLARE ultima_fecha DATE;
SELECT fecha INTO ultima_fecha FROM Compras WHERE cliente = id_cliente ORDER BY fecha DESC LIMIT 1;

RETURN ultima_fecha;

END //
DELIMITER;

