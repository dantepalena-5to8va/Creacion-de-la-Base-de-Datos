DELIMITER //
CREATE FUNCTION dias_ultima_compra(id_cliente INT)
RETURNS INT

BEGIN

DECLARE fecha_ultima DATE
SELECT fecha INTO fecha_ultima FROM Compras WHERE cliente = id_cliente ORDER BY fecha DESC LIMIT 1;

RETURN DATEDIFF(fecha_ultima, NOW());

END //
DELIMITER;

