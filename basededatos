DROP DATABASE IF EXIST pais;
CREATE TABLE pais;

CREATE TABLE provincias(id INT PRIMARY KEY AUTO_INCREMENT, nombre VARCHAR(20), habitantes INT);

CREATE TABLE ciudades(id INT PRIMARY KEY AUTO_INCREMENT, nombre VARCHAR(20), habitantes INT, provincia_id INT, FOREING KEY (provincia_id) REFERENCES provincias(id));

CREATE TABLE clientes(id INT PRIMARY KEY AUTO_INCREMENT, nombre VARCHAR(20), apellido VARCHAR(20), ciudad_id INT, FOREING KEY (ciudad_id) REFERENCES ciudades(id));

CREATE TABLE productos(id INT PRIMARY KEY AUTO_INCREMENT, nombre VARCHAR(20), stock INT);

CREATE TABLE compras(id INT PRIMARY KEY AUTO_INCREMENT, total DECIMAL, producto_id INT, FOREING KEY (producto_id) REFERENCES productos(id));

