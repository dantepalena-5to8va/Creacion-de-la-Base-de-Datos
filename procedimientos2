10 - Registrar una compra asignando automáticamente la fecha actual.
CREATE PROCEDURE Registrar_compra_fechahoy AS
@id INT
@cliente INT
@producto INT
@cant INT

BEGIN

INSERT INTO Compras(id, fecha, cliente, producto, cant) VALUES(@id, CURDATE(), @cliente, @producto, @cant)
END;

11 - Mostrar el producto más caro.
CREATE PROCEDURE Producto_caro AS

BEGIN
SELECT * FROM Productos WHERE precio = MAX(precio)
END;

12 - Reducir el stock de un producto.
CREATE PROCEDURE Reducir_stock AS
@id INT

BEGIN
