24 -  Aumentar todos los precios de una marca un porcentaje determinado
CREATE PROCEDURE Aumentar_precios_marcaporcentaje AS
@marca VARCHAR(40)
@porcentaje INT

BEGIN
UPDATE Productos SET precio = precio + (precio * (@porcentaje / 100)) WHERE marca = @marca
END;




