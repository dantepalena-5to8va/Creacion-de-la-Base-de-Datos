DELIMITER //
CREATE FUNCTION provincia_cliente(cliente INT)
RETURNS VARCHAR(60)

BEGIN
DECLARE nombre_provincia VARCHAR(60);
SELECT Provincias.nombre INTO nombre_provincia FROM Provincias JOIN Ciudades ON Provincias.id = Ciudades.provincia
JOIN Clientes ON Ciudades.id = Clientes.localidad WHERE Clientes.id = cliente;
